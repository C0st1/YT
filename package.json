{
  "name": "youtube-music-desktop",
  "version": "23.0.0",
  "description": "YouTube Music Desktop - Feature-rich desktop app with ad blocking, Discord RPC, mini player, lyrics, visualizer, custom themes, and more",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:win:nsis": "electron-builder --win nsis",
    "build:win:portable": "electron-builder --win portable",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --publish never",
    "test": "jest --verbose",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ test/ --no-error-on-unmatched-pattern",
    "lint:fix": "eslint src/ test/ --fix --no-error-on-unmatched-pattern"
  },
  "keywords": [
    "youtube-music",
    "electron",
    "desktop",
    "music-player",
    "ad-blocker",
    "discord-rpc",
    "mini-player",
    "lyrics",
    "visualizer",
    "custom-themes"
  ],
  "author": "Youtube Music Desktop Contributors",
  "productName": "Youtube Music Desktop",
  "license": "MIT",
  "homepage": "https://github.com/youtube-music-desktop/youtube-music-desktop",
  "repository": {
    "type": "git",
    "url": "https://github.com/youtube-music-desktop/youtube-music-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/youtube-music-desktop/youtube-music-desktop/issues"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.14.1",
    "@xhayper/discord-rpc": "^1.3.3",
    "electron-log": "^5.2.0",
    "electron-store": "^8.1.0"
  },
  "build": {
    "appId": "com.youtube-music.desktop",
    "productName": "Youtube Music Desktop",
    "asarUnpack": [
      "assets/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Youtube Music Desktop",
      "deleteAppDataOnUninstall": true,
      "include": "build/uninstaller.nsh"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.exe"
    }
  }
}
